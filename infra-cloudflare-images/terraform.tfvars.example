# 복사해서 terraform.tfvars 로 사용 (terraform.tfvars 는 .gitignore 됨)

# Cloudflare API Token (또는 환경변수 CLOUDFLARE_API_TOKEN 사용 시 생략)
cloudflare_api_token = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

account_id = "여기에_account_id"
zone_id    = "여기에_zone_id" # 예: shdkej.com 의 zone id

bucket_name   = "openclaw-images"
public_domain = "img.shdkej.com"     # R2 커스텀 도메인 (조회용)
upload_route  = "upload.shdkej.com/*" # 업로드 Worker 라우트

# OpenClaw가 업로드 시 사용할 Bearer 토큰 (openssl rand -hex 32 등으로 생성)
upload_api_token = "여기에_랜덤_시크릿_토큰"

# 선택
max_width     = 1600
output_format = "image/webp"
